{
  "entities": {
    "Usuario": {
      "title": "Usuario",
      "description": "User profile in CajuTech, representing a student, teacher, or farmer.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "perfil": { "type": "string", "enum": ["aluno", "agricultor", "professor"] },
        "regiao": { "type": "string" },
        "criadoEm": { "type": "string" },
        "pontos": { "type": "number" },
        "badges": { "type": "array" },
        "notificacoesHabilitadas": { "type": "boolean" },
        "progresso": {
          "type": "object"
        }
      },
      "required": ["uid", "nome", "email", "perfil", "regiao", "criadoEm", "pontos", "badges", "progresso"]
    },
    "Diagnostico": {
      "title": "Diagnostico",
      "description": "AI-assisted pest or disease identification record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "usuarioId": { "type": "string" },
        "fotoURL": { "type": "string" },
        "praga": { "type": "string" },
        "saudavel": { "type": "boolean" },
        "gravidade": { "type": "string", "enum": ["nenhuma", "leve", "moderada", "grave"] },
        "descricao": { "type": "string" },
        "recomendacoes": { "type": "array" },
        "prevencao": { "type": "array" },
        "criadoEm": { "type": "string" }
      },
      "required": ["id", "usuarioId", "fotoURL", "praga", "saudavel", "gravidade", "descricao", "recomendacoes", "prevencao", "criadoEm"]
    },
    "AlertaNotificacao": {
      "title": "AlertaNotificacao",
      "description": "Push notification sent to farmers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "usuarioId": { "type": "string" },
        "titulo": { "type": "string" },
        "mensagem": { "type": "string" },
        "tipo": { "type": "string", "enum": ["clima", "praga"] },
        "lida": { "type": "boolean" },
        "criadoEm": { "type": "string" }
      },
      "required": ["id", "usuarioId", "titulo", "mensagem", "tipo", "lida", "criadoEm"]
    }
  },
  "firestore": {
    "/usuarios/{uid}": {
      "schema": "Usuario",
      "description": "User profiles"
    },
    "/diagnosticos/{id}": {
      "schema": "Diagnostico",
      "description": "AI pest diagnostics history"
    },
    "/notificacoes/{id}": {
      "schema": "AlertaNotificacao",
      "description": "Received push alerts history"
    }
  }
}
